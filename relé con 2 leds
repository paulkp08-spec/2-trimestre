const int ledPin = 2;

void setup() {
  Serial.begin(9600);
  // Configura o pino do LED como saída
  pinMode(2, OUTPUT);
  pinMode(15, OUTPUT);
}

void loop() {
  digitalWrite(2, HIGH); // Liga o LED
  Serial.print("Jonnathan");
  digitalWrite(15, HIGH); // Liga o Rele
  delay(500); // Espera 1 segundo
  
  digitalWrite(2 , LOW);   // Desliga o LED
  Serial.print("Carabajo");
  digitalWrite(15 , LOW);   // Desliga o Rele
  
  delay(500);
}
